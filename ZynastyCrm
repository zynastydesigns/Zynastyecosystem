<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zynasty CRM — Studio Pipeline</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;1,500&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#24231F; --ink-soft:#3A382F; --ivory:#F1EDE3; --ivory-dim:#E7E1D2;
    --card:#FBF9F4; --brass:#A9812F; --brass-soft:#D8C186; --teal:#375E56;
    --clay:#B1503D; --line:#DAD3C0; --shadow: 0 12px 30px rgba(36,35,31,0.12);
  }
  *{box-sizing:border-box;}
  body{margin:0;font-family:'Inter',sans-serif;background:var(--ivory);color:var(--ink);}
  h1,h2,h3,.brand{font-family:'Fraunces',serif;}
  .mono{font-family:'IBM Plex Mono',monospace;}

  #login-view{display:flex;min-height:100vh;}
  .login-brand{flex:1;background:var(--ink);color:var(--ivory);display:flex;flex-direction:column;justify-content:space-between;padding:56px;overflow:hidden;}
  .login-brand .brand{font-size:28px;font-style:italic;font-weight:500;letter-spacing:0.02em;}
  .login-brand .tagline{font-size:15px;color:var(--brass-soft);margin-top:10px;max-width:320px;line-height:1.5;}
  .swatch-strip{display:flex;gap:10px;margin-top:auto;}
  .swatch{width:38px;height:52px;border-radius:3px;box-shadow:0 4px 10px rgba(0,0,0,0.25);}
  .login-brand .foot{font-size:12px;color:#8b8a7f;margin-top:16px;}

  .login-panel{flex:1;display:flex;align-items:center;justify-content:center;padding:40px;}
  .login-card{width:100%;max-width:380px;}
  .login-card .eyebrow{font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--teal);font-weight:600;margin-bottom:10px;}
  .login-card h1{font-size:30px;margin:0 0 8px 0;font-weight:600;}
  .login-card p.sub{margin:0 0 32px 0;color:#6b6a5e;font-size:14.5px;}
  label{display:block;font-size:13px;font-weight:600;color:var(--ink-soft);margin-bottom:6px;}
  .field{margin-bottom:18px;}
  input[type=email], input[type=password]{
    width:100%;padding:12px 14px;font-size:15px;font-family:'Inter',sans-serif;
    border:1px solid var(--line);border-radius:6px;background:var(--card);color:var(--ink);
    transition:border-color .15s, box-shadow .15s;
  }
  input[type=email]:focus, input[type=password]:focus{
    outline:none;border-color:var(--brass);box-shadow:0 0 0 3px rgba(169,129,47,0.18);
  }
  .error-msg{color:var(--clay);font-size:13px;margin:-8px 0 16px 0;min-height:16px;}
  button.submit{
    width:100%;padding:13px;background:var(--ink);color:var(--ivory);border:none;border-radius:6px;
    font-size:15px;font-weight:600;cursor:pointer;letter-spacing:0.01em;transition:background .15s, transform .1s;
  }
  button.submit:hover{background:#37352C;}
  button.submit:active{transform:translateY(1px);}
  .hint{font-size:12.5px;color:#918f80;margin-top:16px;text-align:center;}

  #dashboard-view{display:none;min-height:100vh;}
  .app-shell{display:flex;min-height:100vh;}
  .sidebar{width:220px;background:var(--ink);color:var(--ivory-dim);padding:28px 18px;flex-shrink:0;display:flex;flex-direction:column;}
  .sidebar .brand{font-size:19px;font-style:italic;color:var(--ivory);margin-bottom:36px;}
  .nav-item{padding:10px 12px;border-radius:6px;font-size:14px;margin-bottom:4px;cursor:pointer;display:flex;align-items:center;gap:10px;color:#c9c7b8;transition:background .15s,color .15s;}
  .nav-item .dot{width:6px;height:6px;border-radius:50%;background:currentColor;opacity:0.5;}
  .nav-item.active{background:rgba(216,193,134,0.14);color:var(--brass-soft);font-weight:600;}
  .nav-item.active .dot{opacity:1;background:var(--brass-soft);}
  .nav-item:hover{color:var(--ivory);}
  .sidebar .logout{margin-top:auto;padding-top:18px;border-top:1px solid #3d3b32;font-size:13px;color:#9b998a;cursor:pointer;}
  .sidebar .logout:hover{color:var(--clay);}

  .main{flex:1;padding:36px 44px;max-width:1180px;}
  .topbar{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:32px;}
  .topbar h1{font-size:26px;margin:0 0 4px 0;font-weight:600;}
  .topbar .welcome{color:#6b6a5e;font-size:14.5px;}
  .who{display:flex;align-items:center;gap:10px;font-size:13.5px;color:var(--ink-soft);}
  .avatar{width:34px;height:34px;border-radius:50%;background:var(--brass);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px;font-family:'Fraunces',serif;}

  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;}
  .stat-card{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:20px;box-shadow:var(--shadow);}
  .stat-card .label{font-size:12.5px;color:#8b8a7c;text-transform:uppercase;letter-spacing:0.06em;font-weight:600;}
  .stat-card .value{font-size:28px;margin-top:8px;font-weight:500;}
  .stat-card .delta{font-size:12.5px;margin-top:6px;color:var(--teal);}

  .panel{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:24px;box-shadow:var(--shadow);}
  .panel h2{font-size:17px;margin:0 0 18px 0;font-weight:600;}
  table{width:100%;border-collapse:collapse;font-size:14px;}
  th{text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:0.05em;color:#8b8a7c;padding:0 12px 10px 12px;border-bottom:1px solid var(--line);font-weight:600;}
  td{padding:14px 12px;border-bottom:1px solid var(--line);}
  tr:last-child td{border-bottom:none;}
  .swatch-chip{display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:500;}
  .swatch-chip .sq{width:11px;height:11px;border-radius:2px;display:inline-block;}
  .amt{font-family:'IBM Plex Mono',monospace;font-size:13.5px;color:var(--ink-soft);}

  @media (max-width:820px){
    #login-view{flex-direction:column;}
    .login-brand{padding:36px;min-height:220px;}
    .stats{grid-template-columns:repeat(2,1fr);}
    .app-shell{flex-direction:column;}
    .sidebar{width:100%;flex-direction:row;align-items:center;padding:16px 20px;overflow-x:auto;}
    .sidebar .brand{margin-bottom:0;margin-right:20px;}
    .sidebar .logout{margin-top:0;margin-left:auto;border-top:none;padding-top:0;}
    .main{padding:24px;}
  }
</style>
</head>
<body>

<div id="login-view">
  <div class="login-brand">
    <div>
      <div class="brand">Zynasty CRM</div>
      <div class="tagline">The studio pipeline — leads, quotations, and client relationships for Zynasty Design, in one place.</div>
    </div>
    <div>
      <div class="swatch-strip">
        <div class="swatch" style="background:#A9812F"></div>
        <div class="swatch" style="background:#375E56"></div>
        <div class="swatch" style="background:#B1503D"></div>
        <div class="swatch" style="background:#D8C186"></div>
        <div class="swatch" style="background:#5C5A4E"></div>
      </div>
      <div class="foot">Prototype build · not connected to production client data</div>
    </div>
  </div>

  <div class="login-panel">
    <div class="login-card">
      <div class="eyebrow">Studio Access</div>
      <h1>Sign in</h1>
      <p class="sub">Enter your studio credentials to open the CRM dashboard.</p>

      <form id="login-form" novalidate>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" placeholder="you@zynastydesigns.com" autocomplete="username" required>
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" required>
        </div>
        <div class="error-msg" id="error-msg"></div>
        <button type="submit" class="submit">Enter studio</button>
      </form>
      <div class="hint">Prototype: any valid email + a password (6+ characters) signs you in.</div>
    </div>
  </div>
</div>

<div id="dashboard-view">
  <div class="app-shell">
    <div class="sidebar">
      <div class="brand">Zynasty CRM</div>
      <div class="nav-item active"><span class="dot"></span> Overview</div>
      <div class="nav-item"><span class="dot"></span> Leads</div>
      <div class="nav-item"><span class="dot"></span> Clients</div>
      <div class="nav-item"><span class="dot"></span> Projects</div>
      <div class="nav-item"><span class="dot"></span> Quotations</div>
      <div class="logout" id="logout-btn">Sign out</div>
    </div>

    <div class="main">
      <div class="topbar">
        <div>
          <h1>Overview</h1>
          <div class="welcome">Here's what's moving across the studio pipeline today.</div>
        </div>
        <div class="who">
          <div class="avatar" id="avatar-initial">Z</div>
          <span id="who-email">you@zynastydesigns.com</span>
        </div>
      </div>

      <div class="stats">
        <div class="stat-card">
          <div class="label">Active Leads</div>
          <div class="value mono">14</div>
          <div class="delta">+3 this week</div>
        </div>
        <div class="stat-card">
          <div class="label">Projects In Progress</div>
          <div class="value mono">7</div>
          <div class="delta">2 awaiting KYC</div>
        </div>
        <div class="stat-card">
          <div class="label">Quotations Sent</div>
          <div class="value mono">9</div>
          <div class="delta">4 pending reply</div>
        </div>
        <div class="stat-card">
          <div class="label">Pipeline Value</div>
          <div class="value mono">₹38.2L</div>
          <div class="delta">across open projects</div>
        </div>
      </div>

      <div class="panel">
        <h2>Recent Activity</h2>
        <table>
          <thead>
            <tr><th>Client</th><th>Stage</th><th>Last Update</th><th style="text-align:right">Value</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>Mrs. Anjali Rao</td>
              <td><span class="swatch-chip"><span class="sq" style="background:#A9812F"></span>Quoted</span></td>
              <td>2 days ago</td>
              <td class="amt" style="text-align:right">₹6,40,000</td>
            </tr>
            <tr>
              <td>Mr. Devraj Shah</td>
              <td><span class="swatch-chip"><span class="sq" style="background:#375E56"></span>In Discussion</span></td>
              <td>Today</td>
              <td class="amt" style="text-align:right">₹4,10,000</td>
            </tr>
            <tr>
              <td>Ms. Priya Menon</td>
              <td><span class="swatch-chip"><span class="sq" style="background:#5C5A4E"></span>Won</span></td>
              <td>1 week ago</td>
              <td class="amt" style="text-align:right">₹9,85,000</td>
            </tr>
            <tr>
              <td>Dr. Kabir Malhotra</td>
              <td><span class="swatch-chip"><span class="sq" style="background:#B1503D"></span>Follow-up Due</span></td>
              <td>3 days ago</td>
              <td class="amt" style="text-align:right">₹2,75,000</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  const loginView = document.getElementById('login-view');
  const dashView = document.getElementById('dashboard-view');
  const form = document.getElementById('login-form');
  const emailInput = document.getElementById('email');
  const passInput = document.getElementById('password');
  const errorMsg = document.getElementById('error-msg');
  const whoEmail = document.getElementById('who-email');
  const avatarInitial = document.getElementById('avatar-initial');
  const logoutBtn = document.getElementById('logout-btn');

  let memorySession = null;
  async function saveSession(email){
    try{
      if (window.storage && window.storage.set){
        await window.storage.set('crm-session', JSON.stringify({ email }), false);
        return;
      }
    }catch(e){}
    memorySession = { email };
  }
  async function loadSession(){
    try{
      if (window.storage && window.storage.get){
        const res = await window.storage.get('crm-session', false);
        if (res && res.value) return JSON.parse(res.value);
        return null;
      }
    }catch(e){}
    return memorySession;
  }
  async function clearSession(){
    try{
      if (window.storage && window.storage.delete){
        await window.storage.delete('crm-session', false);
      }
    }catch(e){}
    memorySession = null;
  }

  function showDashboard(email){
    whoEmail.textContent = email;
    avatarInitial.textContent = email.trim()[0].toUpperCase();
    loginView.style.display = 'none';
    dashView.style.display = 'block';
  }
  function showLogin(){
    dashView.style.display = 'none';
    loginView.style.display = 'flex';
    errorMsg.textContent = '';
    form.reset();
  }

  function isValidEmail(v){
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
  }

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    const email = emailInput.value.trim();
    const password = passInput.value;

    if (!isValidEmail(email)){
      errorMsg.textContent = 'Enter a valid email address.';
      return;
    }
    if (password.length < 6){
      errorMsg.textContent = 'Password must be at least 6 characters.';
      return;
    }
    errorMsg.textContent = '';
    await saveSession(email);
    showDashboard(email);
  });

  logoutBtn.addEventListener('click', async function(){
    await clearSession();
    showLogin();
  });

  (async function init(){
    const session = await loadSession();
    if (session && session.email){
      showDashboard(session.email);
    }
  })();
})();
</script>

</body>
</html>
